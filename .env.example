# Maxwell-Daemon Environment Configuration
# Copy this file to .env and fill in your values.
# See docs/operations/configuration.md for detailed documentation.

# =============================================================================
# LLM Backend API Keys (at least one required for operation)
# =============================================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google AI (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HF_TOKEN=your_hf_token_here

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here

# Together AI
TOGETHER_API_KEY=your_together_api_key_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =============================================================================
# Ollama (local LLM hosting)
# =============================================================================

OLLAMA_HOST=http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# GitHub Authentication
# =============================================================================

# Personal access token with repo scope
GH_TOKEN=your_github_token_here
# GITHUB_TOKEN=your_github_token_here

# =============================================================================
# Maxwell Configuration
# =============================================================================

# Path to main configuration file. The format is YAML, not TOML.
# Default: $XDG_CONFIG_HOME/maxwell-daemon/maxwell-daemon.yaml
#          (i.e. ~/.config/maxwell-daemon/maxwell-daemon.yaml on most systems).
MAXWELL_CONFIG=/path/to/maxwell-daemon.yaml

# Path to fleet manifest (default: fleet.yaml in working directory)
MAXWELL_FLEET_CONFIG=/path/to/fleet.yaml

# Allow environment variable substitution in config (default: true)
MAXWELL_ALLOW_ENV=true

# Redact sensitive values in logs (default: true)
MAXWELL_REDACT_LOGS=true

# Enable aggressive context compression to reduce token usage (default: false)
MAXWELL_AGGRESSIVE_COMPRESSION=false

# Path to contracts directory for design-by-contract enforcement
MAXWELL_CONTRACTS=/path/to/contracts

# =============================================================================
# OpenTelemetry / Telemetry
# =============================================================================

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# XDG Base Directory (used for default config paths)
# =============================================================================

XDG_CONFIG_HOME=/home/user/.config
HOME=/home/user
APPDATA=/home/user/AppData/Roaming

# =============================================================================
# Testing (set automatically by pytest, not usually needed manually)
# =============================================================================

# PYTEST_CURRENT_TEST=module::test_name
