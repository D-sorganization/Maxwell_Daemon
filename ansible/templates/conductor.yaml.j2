version: "1"

backends:
  claude:
    type: claude
    model: claude-sonnet-4-6
    api_key: ${ANTHROPIC_API_KEY}
  ollama:
    type: ollama
    model: llama3.1
    base_url: http://localhost:11434

agent:
  default_backend: {{ conductor_default_backend | default('claude') }}

fleet:
  machines:
{% for host in groups['conductor_fleet'] | default([]) %}
    - name: {{ host }}
      host: {{ hostvars[host]['ansible_host'] }}
      port: 8080
      capacity: {{ hostvars[host]['conductor_capacity'] | default(2) }}
      tags: {{ hostvars[host]['conductor_tags'] | default([]) | to_json }}
{% endfor %}

api:
  enabled: true
  host: "0.0.0.0"
  port: 8080
  auth_token: ${CONDUCTOR_API_TOKEN:-}

budget:
  monthly_limit_usd: null
  alert_thresholds: [0.75, 0.9, 1.0]
  hard_stop: false
