{
  "name": "conductor-vscode",
  "displayName": "CONDUCTOR for Maxwell-Daemon",
  "description": "VS Code control surface for Maxwell-Daemon agents, issues, PRs, and logs.",
  "version": "0.1.0",
  "publisher": "d-sorganization",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:maxwellConductor.agents",
    "onCommand:maxwellConductor.refresh",
    "onCommand:maxwellConductor.dispatchIssue",
    "onCommand:maxwellConductor.openPrDiff",
    "onCommand:maxwellConductor.streamLogs",
    "onCommand:maxwellConductor.configureDaemon"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Maxwell CONDUCTOR",
      "properties": {
        "maxwellConductor.daemonUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8080",
          "description": "Base URL for the Maxwell-Daemon API."
        },
        "maxwellConductor.token": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token for the Maxwell-Daemon API. Leave empty for local open-dev mode."
        },
        "maxwellConductor.defaultMode": {
          "type": "string",
          "enum": [
            "plan",
            "implement"
          ],
          "default": "implement",
          "description": "Default issue dispatch mode."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maxwellConductor",
          "title": "CONDUCTOR",
          "icon": "media/activity.svg"
        }
      ]
    },
    "views": {
      "maxwellConductor": [
        {
          "id": "maxwellConductor.agents",
          "name": "Agents"
        }
      ]
    },
    "commands": [
      {
        "command": "maxwellConductor.refresh",
        "title": "Maxwell: Refresh Agents"
      },
      {
        "command": "maxwellConductor.dispatchIssue",
        "title": "Maxwell: Dispatch GitHub Issue"
      },
      {
        "command": "maxwellConductor.openPrDiff",
        "title": "Maxwell: Open PR Diff"
      },
      {
        "command": "maxwellConductor.streamLogs",
        "title": "Maxwell: Stream Logs in Terminal"
      },
      {
        "command": "maxwellConductor.configureDaemon",
        "title": "Maxwell: Configure Daemon URL"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "maxwellConductor.refresh",
          "when": "view == maxwellConductor.agents",
          "group": "navigation"
        },
        {
          "command": "maxwellConductor.dispatchIssue",
          "when": "view == maxwellConductor.agents",
          "group": "navigation"
        },
        {
          "command": "maxwellConductor.streamLogs",
          "when": "view == maxwellConductor.agents",
          "group": "navigation"
        }
      ]
    }
  }
}
