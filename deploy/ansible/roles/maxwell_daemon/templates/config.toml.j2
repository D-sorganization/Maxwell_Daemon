# maxwell-daemon configuration — managed by Ansible, do not edit by hand.

[server]
host = "127.0.0.1"
port = {{ maxwell_port }}
{% if maxwell_tls_cert %}
tls_cert = "{{ maxwell_tls_cert }}"
tls_key  = "{{ maxwell_tls_key }}"
{% endif %}

[auth]
jwt_secret = "{{ maxwell_jwt_secret }}"

[storage]
data_dir = "{{ maxwell_data_dir }}"
log_dir  = "{{ maxwell_log_dir }}"

[backends]
default = "{{ maxwell_backend }}"

{% if maxwell_anthropic_api_key %}
[backends.anthropic]
api_key = "{{ maxwell_anthropic_api_key }}"
{% endif %}

{% if maxwell_openai_api_key %}
[backends.openai]
api_key = "{{ maxwell_openai_api_key }}"
{% endif %}
