---
# Example fleet inventory — copy to fleet.yml and fill in real hosts.
all:
  vars:
    ansible_user: ubuntu
    ansible_ssh_private_key_file: ~/.ssh/id_ed25519
    maxwell_version: "latest"   # pip version or "git:main"
    maxwell_port: 8765
    maxwell_config_dir: /etc/maxwell-daemon
    maxwell_data_dir: /var/lib/maxwell-daemon

  children:
    maxwell_primary:
      hosts:
        primary-01:
          ansible_host: 192.0.2.10

    maxwell_agents:
      hosts:
        agent-01:
          ansible_host: 192.0.2.20
        agent-02:
          ansible_host: 192.0.2.21
